from flask import Flask

app = Flask(__name__)

@app.route("/")
def home():
    return """
    <h1>🚀 Servidor Flask Local</h1>
    <p>Estado: <b>Operativo</b></p>
    <hr>
    <p>Este es el motor que luego Apache redirigirá en el servidor real.</p>
    """

if __name__ == "__main__":
    app.run(port=5000, debug=True)